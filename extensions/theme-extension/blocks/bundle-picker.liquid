{%- assign namespace = 'app--' | append: app.id -%}
{%- assign bundle_meta = product.metafields[namespace].bundle_groups -%}
{%- if bundle_meta == blank -%}
  {%- comment -%}Fallback for when app.id evaluates to empty in Theme Block testing contexts{%- endcomment -%}
  {%- assign bundle_meta = product.metafields['app--329858121729'].bundle_groups -%}
{%- endif -%}

{%- if bundle_meta.value != blank -%}
  {%- assign bundle_data = bundle_meta.value -%}

  {%- assign short_titles = '' -%}
  {%- for group in bundle_data.groups -%}
    {%- for product in group.products -%}
      {%- assign b_product = all_products[product.handle] -%}
      {%- assign b_short_title = b_product.metafields.custom.short_title.value
        | default: b_product.metafields.custom.short_title
      -%}
      {%- if b_short_title != blank -%}
        {%- capture short_title_json -%}"{{ product.handle }}":{{ b_short_title | json }}{%- endcapture -%}
        {%- if short_titles != '' -%}
          {%- assign short_titles = short_titles | append: ',' -%}
        {%- endif -%}
        {%- assign short_titles = short_titles | append: short_title_json -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endfor -%}
  {%- assign short_titles_json = '{' | append: short_titles | append: '}' -%}

  <pgb-bundle-picker
    class="pgb-bundle-picker"
    data-product-id="{{ product.id }}"
    data-product-gid="gid://shopify/Product/{{ product.id }}"
    data-bundle-config="{{ bundle_data | json | escape }}"
    data-short-titles="{{ short_titles_json | escape }}"
    data-locale="{{ request.locale.iso_code }}"
    data-currency-symbol="{{ cart.currency.symbol }}"
    data-heading="{{ block.settings.heading | escape }}"
    data-layout="{{ block.settings.layout }}"
  >
    <noscript>
      <p>{{ 'bundle.noscript' | t }}</p>
    </noscript>
  </pgb-bundle-picker>

  {{ 'bundle-picker.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'bundle-picker.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "t:bundle.name",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:bundle.heading",
      "default": "t:bundle.heading"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:bundle.layout.label",
      "options": [
        { "value": "list", "label": "t:bundle.layout.options.list" },
        { "value": "grid", "label": "t:bundle.layout.options.grid" }
      ],
      "default": "list"
    }
  ]
}
{% endschema %}
