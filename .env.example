# Shopify app credentials (from `shopify app env show`)
SHOPIFY_API_KEY=your_client_id_here
SHOPIFY_API_SECRET=your_api_secret_here
SCOPES=read_products,write_products,read_cart_transforms,write_cart_transforms

# Public URL where the app is hosted
SHOPIFY_APP_URL=https://bundler.icarsoft-france.fr

# Port the app listens on inside the container (matches docker-compose)
PORT=3100

# SQLite database path (matches the Docker volume mount)
DATABASE_URL=file:/data/dev.sqlite
